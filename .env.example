# .env.example — MẪU CẤU HÌNH
# LƯU Ý: Đây chỉ là file mẫu để tham khảo. KHÔNG chứa secrets thật.
# - Sao chép file này thành `.env` trên máy chủ hoặc local và điền giá trị thực.
# - Không commit file `.env` chứa thông tin nhạy cảm vào Git.

# ==========================================
# 📝 LOGGING CONFIG
# ==========================================
LOG_LEVEL=INFO
CONSOLE_LOG_LEVEL=INFO
LOG_FILE=logs/bot_activity.log
MAX_LOG_SIZE=10485760
BACKUP_COUNT=5

# ==========================================
# 📊 DATABASE
# ==========================================
DATABASE_PATH=data/code_history.db
DATABASE_BACKUP_DAYS=30

# ==========================================
# ⚡ PERFORMANCE (OPTIMIZED v3.6)
# ==========================================
MAX_CONCURRENT_TASKS=4
PAGE_LOAD_TIMEOUT=5000
CLOUDFLARE_WAIT_TIMEOUT=60000

# ==========================================
# 🛡️ ANTI-BAN (OPTIMIZED FOR SPEED)
# ==========================================
MIN_DELAY_BETWEEN_SUBMITS=0.8
REQUESTS_PER_MINUTE=30
MAX_BURST=5

# ==========================================
# 🎯 AUTO-SUBMIT SETTINGS (v3.6)
# ==========================================
AUTO_SUBMIT_ENABLED=True
AUTO_SUBMIT_DELAY=0.3
HUMAN_LIKE_TYPING_SPEED=0.05
RANDOM_DELAY_MIN=0.1
RANDOM_DELAY_MAX=0.5

# ==========================================
# 🔍 INPUT DETECTION (v3.6)
# ==========================================
INPUT_DETECTION_STRATEGY=advanced
INPUT_DETECTION_TIMEOUT=5000
MULTIPLE_SELECTOR_ATTEMPTS=4

# ==========================================
# 📊 RESULT DETECTION (v3.6)
# ==========================================
RESULT_DETECTION_METHODS=5
RESULT_DETECTION_TIMEOUT=5000
SCREENSHOT_ON_UNKNOWN=True

# ==========================================
# 🔄 SESSION ROTATION (v3.6)
# ==========================================
SESSION_ROTATION_ENABLED=True
SESSION_ROTATION_INTERVAL=100
SESSION_ROTATION_DELAY=2.0

# ==========================================
# 📟 MONITORING & ALERTS
# ==========================================
MONITORING_ENABLED=True
MONITORING_CHECK_INTERVAL=60
ALERT_ON_ERROR=True

# ==========================================
# 🌐 BROWSER CONFIG (FIXED WINDOW SIZE)
# ==========================================
BROWSER_PROFILE_DIR=HoSo_Bot_Vip
HEADLESS_MODE=False
VIEWPORT_WIDTH=1024
VIEWPORT_HEIGHT=768
WINDOW_POSITION_X=0
WINDOW_POSITION_Y=0

# ==========================================
# 📋 FEATURES
# ==========================================
ENABLE_RETRY=True
ENABLE_CIRCUIT_BREAKER=True
ENABLE_DATABASE_TRACKING=True
ENABLE_RATE_LIMITING=True
ENABLE_MONITORING=True
ENABLE_AUTO_SESSION_ROTATION=True
ENABLE_ADVANCED_ANTI_DETECTION=True

# ==========================================
# ⚡ ULTRA FAST QUEUE MODE
# ==========================================
MAX_TELEGRAM_DELAY_SECONDS=999
MESSAGE_QUEUE_MAXSIZE=1500
MESSAGE_WORKERS=4
TELEGRAM_CATCH_UP=false

# ==========================================
# 🚀 FAST SUBMIT
# ==========================================
RESULT_WAIT=500
AUTO_OPEN_MISSING_TABS=true
AUTO_OPEN_TAB_WAIT=0.5
RUN_SYSTEM_TEST_ON_START=false
SCREENSHOT_ON_UNKNOWN=true
BACKGROUND_MAINTENANCE_DELAY=300

# ==========================================
# 💓 HEARTBEAT
# ==========================================
HEARTBEAT_INTERVAL=300

# ==========================================
# 🖥️ BROWSER MANAGER — Microsoft Edge
# ==========================================
# Đường dẫn Edge (thay nếu máy cài chỗ khác)
BROWSER_EXE_PATH=C:\Program Files (x86)\Microsoft\Edge\Application\msedge.exe

# Profile Edge đang dùng (Default hoặc Profile 1, Profile 2...)
BROWSER_PROFILE=Default

# true = tự kill TOÀN BỘ Edge trong Task Manager trước khi mở (mặc định true)
AUTO_CLOSE_OLD_BROWSER=false

# true = tự mở Edge mới sau khi kill
AUTO_LAUNCH_BROWSER=false

# ==========================================
# ☑️ CLOUD/CF MANUAL VERIFICATION (NEW)
# ==========================================
# Nếu SKIP_AUTO_VERIFY=true thì bot SẼ KHÔNG cố tự click/verify Cloudflare/Turnstile.
# Thay vào đó bot sẽ đưa tab lên và chờ người dùng hoàn tất xác minh thủ công.
# Giá trị timeout là giây (ví dụ 300 = 5 phút).
SKIP_AUTO_VERIFY=true
MANUAL_CF_TIMEOUT=300

# ==========================================
# 🔐 TELEGRAM / EXTERNAL KEYS (DO NOT COMMIT SECRETS)
# ==========================================
# API_ID and API_HASH: điền vào file .env trên máy chủ, KHÔNG commit.
# Example placeholders (replace locally):
# API_ID=123456
# API_HASH=your_api_hash_here
# GROQ_API_KEY=your_groq_api_key
# TESSERACT_PATH=C:\Program Files\Tesseract-OCR\tesseract.exe

# END OF .env.example
